VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# ── ADMIN CMS PASSWORD ────────────────────────────────────────────────────
# Change this to a secure password before deploying!
VITE_ADMIN_PASSWORD=""
